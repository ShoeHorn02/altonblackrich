{
  "name": "spark-react",
  "homepage": "/",
  "version": "3.3.1",
  "description": "Spark - Admin & Dashboard Template [ReactJS]",
  "author": "Paul Laros <support@bootlab.io>",
  "private": true,
  "scripts": {
    "sass:compile": "sass --load-path=./node_modules --watch src/assets/scss:public/css",
    "build:css": "sass --load-path=./node_modules src/assets/scss:public/css",
    "build:js": "NODE_OPTIONS=--openssl-legacy-provider react-scripts build",
    "watch:css": "chokidar \"src/assets/scss/**/*\" -c \"npm run build:css\"",
    "watch:js": "NODE_OPTIONS=--openssl-legacy-provider react-scripts start",
    "start": "npm-run-all -p build:css watch:*",
    "build": "npm-run-all -p build:*"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    "> 0.25%",
    "ie >= 11",
    "not op_mini all",
    "not dead"
  ],
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "1.2.28",
    "@fortawesome/free-brands-svg-icons": "5.13.0",
    "@fortawesome/free-regular-svg-icons": "5.13.0",
    "@fortawesome/free-solid-svg-icons": "5.13.0",
    "@fortawesome/react-fontawesome": "0.1.9",
